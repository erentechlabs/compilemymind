{
  "site": {
    "name": "Compile My Mind",
    "publisher_name": "Compile My Mind",
    "base_url": "https://www.compilemymind.com/",
    "timezone": "Europe/Istanbul",
    "content_dir": "content/posts",
    "language": "en"
  },
  "gemini": {
    "text_model": "gemini-3.5-flash",
    "qa_model": "gemini-3.5-flash",
    "grounded_research_model": "gemini-3.5-flash",
    "image_model": "gemini-3.1-flash-image",
    "temperature": 0.45,
    "article_temperature": 0.35,
    "qa_temperature": 0.1,
    "max_output_tokens": 32768,
    "enable_google_search_grounding": true,
    "grounded_research_fallback_to_feeds": true,
    "enable_image_generation": false,
    "model_upgrade": {
      "enabled": true,
      "family": "flash",
      "stable_only": true,
      "max_major_jump": 1,
      "min_input_token_limit": 32768,
      "min_output_token_limit": 8192
    }
  },
  "github_models": {
    "enabled": true,
    "endpoint": "https://models.github.ai/inference/chat/completions",
    "model": "openai/gpt-4o-mini",
    "lightweight_tasks": ["topic_selection", "metadata_enrichment"],
    "max_output_tokens": 4096,
    "topic_selection_temperature": 0.1,
    "topic_selection_max_output_tokens": 1800
  },
  "publishing": {
    "min_words": 1400,
    "max_similarity": 0.34,
    "max_title_similarity": 0.48,
    "max_source_similarity": 0.3,
    "max_source_title_similarity": 0.7,
    "max_previous_draft_similarity": 0.9,
    "max_heading_similarity": 0.7,
    "max_ngram_overlap": 0.28,
    "max_search_intent_similarity": 0.72,
    "max_slug_length": 72,
    "max_regeneration_attempts": 3,
    "max_topic_attempts": 3,
    "quality_min_score": 0.82,
    "ai_qa_min_score": 0.8,
    "topic_relevance_min_score": 0.78,
    "required_source_count": 3,
    "minimum_official_sources": 1,
    "required_claim_evidence_count": 3,
    "require_table": true,
    "prefer_internal_links": 3,
    "minimum_internal_post_links": 2,
    "minimum_practical_elements": 2,
    "max_new_posts_per_run": 1
  },
  "source_validation": {
    "max_candidates_per_run": 18,
    "min_title_similarity": 0.08,
    "min_relevance_similarity": 0.05,
    "min_claim_source_similarity": 0.12,
    "min_claim_confidence": 0.8,
    "max_age_days": 730,
    "max_release_age_days": 365,
    "blocked_path_terms": ["/search", "/tag/", "/tags/", "/category/", "/categories/", "/advertis", "/sponsor"],
    "blocked_page_terms": ["access denied", "sign in to continue", "log in to continue", "enable javascript to continue"],
    "trusted_domains": [
      "learn.microsoft.com", "docs.microsoft.com", "microsoft.com", "azure.microsoft.com", "techcommunity.microsoft.com",
      "aws.amazon.com", "cloud.google.com", "kubernetes.io", "github.com", "github.blog", "docs.github.com", "developer.mozilla.org",
      "ietf.org", "nvlpubs.nist.gov", "nist.gov", "owasp.org", "cisa.gov", "docker.com", "opentelemetry.io",
      "cloudflare.com", "python.org", "nodejs.org", "go.dev", "rust-lang.org", "oracle.com"
    ]
  },
  "maintenance": {
    "max_articles_per_run": 2,
    "review_after_days": 45,
    "link_timeout_seconds": 12,
    "treat_403_as_broken": false,
    "update_similarity_floor": 0.55
  },
  "revalidation_intervals": {
    "pricing_days": 7,
    "release_days": 14,
    "certification_days": 21,
    "cloud_configuration_days": 35,
    "default_days": 60,
    "stable_protocol_days": 150
  },
  "revision": {
    "enabled": true,
    "max_posts_per_run": 1,
    "min_paragraphs": 5,
    "min_preserved_length_ratio": 0.72
  },
  "topic_scope": {
