{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- $seen := newScratch -}}
  {{- $minTagArticles := site.Params.tagPolicy.minArticlesToIndex | default 3 -}}
  {{- range .Data.Pages -}}
    {{- $thinTag := and (eq .Kind "term") (eq .Type "tags") (lt (len .Pages) $minTagArticles) -}}
    {{- $redirect := or .Params.redirect .Params.redirectURL -}}
    {{- $canonical := .Permalink -}}
    {{- $alreadySeen := $seen.Get $canonical -}}
    {{- if and (not .Draft) (not .Params.noindex) (not $thinTag) (not $redirect) (not $alreadySeen) -}}
      {{- $seen.Set $canonical true -}}
  <url>
    <loc>{{ $canonical }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
    {{- end }}
  </url>
    {{- end -}}
  {{- end -}}
</urlset>
