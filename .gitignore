# Hugo build output - Cloudflare Pages rebuilds this from source
public/
.hugo_build.lock

# Hugo resource cache (generated images, fingerprinted assets)
resources/

# OS artifacts
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Python local artifacts
__pycache__/
*.py[cod]

# Per-run autonomous publication artifacts. Durable state, configuration, and
# stable reports remain tracked so scheduled runs can resume safely.
.autopublisher/publish-result.json
.autopublisher/release-gate-result.json
.autopublisher/dashboard.json
.autopublisher/logs/*.jsonl
infra-result.json
